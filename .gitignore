# Virtual environments
.venv/
venv/
env/

# uv
# (uv.lock IS committed for reproducible installs)

# Trace data and caches — large; not committed.
# Only data/*.jsonl (question files) and data/README.md are committed.
# Everything else under data/ — model dirs, trace pools, caches, and any
# symlinks to external data pools — stays local.
data/*
!data/*.jsonl
!data/README.md

# Generation pipeline outputs
outputs*/
probe_results/
*.log

# Experiment results (regenerated by examples/run_experiment.py)
results/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
build/
dist/
*.egg-info/
.eggs/

# Jupyter
.ipynb_checkpoints/

# IDE / OS
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Testing / typing caches
.pytest_cache/
.coverage
.mypy_cache/
.ruff_cache/

# Claude Code
.claude/

# Docs are kept local, not released — except data_format.md, which documents
# the trace pickle schema users need to supply/generate data.
docs/*
!docs/data_format.md
